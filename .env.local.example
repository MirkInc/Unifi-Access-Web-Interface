# Copy this file to .env.local and fill in your values

# MongoDB connection string (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/unifi-access?retryWrites=true&w=majority

# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your deployment URL (http://localhost:3000 for dev)
NEXTAUTH_URL=http://localhost:3000

# Resend API key for sending emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From email address for password reset emails
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Admin email - first user to log in with this email gets admin role
# (Only used during initial setup)
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
